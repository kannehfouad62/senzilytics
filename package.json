{
  "name": "senzilytics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "permissions:moc": "tsx --env-file=.env prisma/grant-moc-permissions.ts",
    "start": "next start",
    "lint": "eslint",
    "test": "node scripts/run-tests.mjs",
    "check": "npm run lint && npm test && npm run build",
    "verify:production": "tsx --env-file=.env scripts/verify-production-env.ts",
    "db:deploy": "prisma migrate deploy",
    "platform:grant": "tsx --env-file=.env scripts/grant-platform-admin.ts",
    "password:reset": "tsx --env-file=.env scripts/reset-user-password.ts",
    "demo:seed": "tsx --env-file=.env scripts/seed-public-demo.ts",
    "mobile:install": "npm --prefix apps/mobile install",
    "mobile:check": "npm --prefix apps/mobile run check",
    "postinstall": "prisma generate",
    "repair:workflows": "tsx prisma/repair-workflows.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/blob": "^2.6.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.46.0",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "resend": "^6.17.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
