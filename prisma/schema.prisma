model Organization {
  id                  String             @id @default(cuid())
  name                String
  industry            String?
  address             String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  status              OrganizationStatus @default(ACTIVE)
  allowedEmailDomains String[]

  sites                        Site[]
  users                        User[]
  activityLogs                 ActivityLog[]
  notifications                Notification[]
  workflowTemplates            WorkflowTemplate[]
  workflowInstances            WorkflowInstance[]
  documents                    Document[]
  auditChecklistTemplates      AuditChecklistTemplate[]
  inspectionChecklistTemplates InspectionChecklistTemplate[]
  risks                        Risk[]
  managementOfChanges          ManagementOfChange[]

  auditProgramsV2 AuditProgram[] @relation("AuditProgramOrganization")

  auditSchedulesV2 AuditSchedule[] @relation("AuditScheduleOrganization")

  auditProtocolsV2 AuditProtocol[] @relation("AuditProtocolOrganization")

  enterpriseAuditsV2 EnterpriseAudit[] @relation("EnterpriseAuditOrganization")

  enterpriseAuditEvidenceV2 EnterpriseAuditEvidence[] @relation("EnterpriseAuditEvidenceOrganization")

  enterpriseAuditFindingsV2 EnterpriseAuditFinding[] @relation("EnterpriseAuditFindingOrganization")

  enterpriseAuditHistoryV2 EnterpriseAuditHistory[]        @relation("EnterpriseAuditHistoryOrganization")
  safetyObservations       SafetyObservation[]
  trainingCourses          TrainingCourse[]
  trainingRequirements     TrainingRequirement[]
  permits                  Permit[]
  chemicals                Chemical[]
  environmentalMetrics     EnvironmentalMetricDefinition[]
  environmentalTargets     EnvironmentalTarget[]
  esgFrameworks            EsgFramework[]
  esgMetrics               EsgMetricDefinition[]
  esgDisclosurePeriods     EsgDisclosurePeriod[]
  esgInitiatives           EsgInitiative[]
  jobSafetyAnalyses        JobSafetyAnalysis[]
  identityProviders        OrganizationIdentityProvider[]
  tenantInvitations        TenantInvitation[]
}

model Site {
  id             String       @id @default(cuid())
  name           String
  address        String?
  city           String?
  state          String?
  country        String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  departments         Department[]
  incidents           Incident[]
  audits              Audit[]
  inspections         Inspection[]
  complianceItems     ComplianceItem[]
  risks               Risk[]
  managementOfChanges ManagementOfChange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditProgramScopesV2 AuditProgramSite[] @relation("AuditProgramSiteScope")

  auditSchedulesV2     AuditSchedule[]          @relation("AuditScheduleSite")
  enterpriseAuditsV2   EnterpriseAudit[]        @relation("EnterpriseAuditSite")
  safetyObservations   SafetyObservation[]
  trainingRequirements TrainingRequirement[]
  jobSafetyAnalyses    JobSafetyAnalysis[]
  permits              Permit[]
  chemicalInventories  ChemicalInventory[]
  environmentalData    EnvironmentalDataPoint[]
}

model Department {
  id     String @id @default(cuid())
  name   String
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  users               User[]
  risks               Risk[]
  managementOfChanges ManagementOfChange[]

  auditProgramScopesV2 AuditProgramDepartment[] @relation("AuditProgramDepartmentScope")

  auditSchedulesV2     AuditSchedule[]       @relation("AuditScheduleDepartment")
  enterpriseAuditsV2   EnterpriseAudit[]     @relation("EnterpriseAuditDepartment")
  safetyObservations   SafetyObservation[]
  trainingRequirements TrainingRequirement[]

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  jobSafetyAnalyses JobSafetyAnalysis[]
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  password        String?
  role            UserRole  @default(EMPLOYEE)
  jobTitle        String?
  phone           String?
  isActive        Boolean   @default(true)
  isPlatformAdmin Boolean   @default(false)
  invitedAt       DateTime?
  activatedAt     DateTime?
  lastLoginAt     DateTime?
  sessionVersion  Int       @default(0)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  reportedIncidents         Incident[]                  @relation("ReportedIncidents")
  assignedInvestigations    Investigation[]             @relation("InvestigationAssignedUser")
  assignedActions           CorrectiveAction[]
  leadAudits                Audit[]                     @relation("AuditLeadAuditor")
  auditTeamMemberships      AuditTeamMember[]
  auditResponses            AuditResponse[]             @relation("AuditResponseAnsweredBy")
  leadInspections           Inspection[]                @relation("InspectionLeadInspector")
  inspectionTeamMemberships InspectionTeamMember[]
  inspectionResponses       InspectionResponse[]        @relation("InspectionResponseAnsweredBy")
  trainingRecords           TrainingRecord[]            @relation("TrainingRecordLearner")
  assignedTrainingRecords   TrainingRecord[]            @relation("TrainingRecordAssignedBy")
  createdTrainingCourses    TrainingCourse[]            @relation("TrainingCourseCreatedBy")
  ownedComplianceItems      ComplianceItem[]            @relation("ComplianceItemOwner")
  ownedPermits              Permit[]                    @relation("PermitOwner")
  complianceEvaluations     ComplianceEvaluation[]      @relation("ComplianceEvaluationUser")
  reviewedChemicals         Chemical[]                  @relation("ChemicalReviewedBy")
  enteredEnvironmentalData  EnvironmentalDataPoint[]    @relation("EnvironmentalDataEnteredBy")
  approvedEnvironmentalData EnvironmentalDataPoint[]    @relation("EnvironmentalDataApprovedBy")
  environmentalRevisions    EnvironmentalDataRevision[] @relation("EnvironmentalRevisionChangedBy")
  enteredEsgData            EsgDataPoint[]              @relation("EsgDataEnteredBy")
  approvedEsgPeriods        EsgDisclosurePeriod[]       @relation("EsgPeriodApprovedBy")
  publishedEsgPeriods       EsgDisclosurePeriod[]       @relation("EsgPeriodPublishedBy")
  ownedEsgInitiatives       EsgInitiative[]             @relation("EsgInitiativeOwner")
  createdJsas               JobSafetyAnalysis[]         @relation("JsaCreatedBy")
  ownedJsas                 JobSafetyAnalysis[]         @relation("JsaOwner")
  approvedJsas              JobSafetyAnalysis[]         @relation("JsaApprovedBy")
  jsaAcknowledgments        JsaAcknowledgment[]
  activityLogs              ActivityLog[]
  notifications             Notification[]
  uploadedDocuments         Document[]
  sentTenantInvitations     TenantInvitation[]          @relation("TenantInvitationSender")
  acceptedTenantInvitations TenantInvitation[]          @relation("TenantInvitationAcceptor")
  passwordResetTokens       PasswordResetToken[]

  ownedRisks           Risk[]        @relation("RiskOwner")
  ownedRiskControls    RiskControl[] @relation("RiskControlOwner")
  completedRiskReviews RiskReview[]  @relation("RiskReviewCompletedBy")

  startedWorkflowInstances WorkflowInstance[]
  assignedWorkflowSteps    WorkflowInstanceStep[] @relation("WorkflowAssignedUser")
  completedWorkflowSteps   WorkflowInstanceStep[] @relation("WorkflowCompletedBy")

  requestedChanges ManagementOfChange[] @relation("MocRequestor")
  ownedChanges     ManagementOfChange[] @relation("MocOwner")
  mocApprovals     MocApproval[]        @relation("MocApprover")
  assignedMocTasks MocTask[]            @relation("MocTaskAssignee")
  verifiedMocTasks MocTask[]            @relation("MocTaskVerifiedBy")

  ownedAuditProgramsV2       AuditProgram[]            @relation("AuditProgramOwner")
  ledAuditSchedulesV2        AuditSchedule[]           @relation("AuditScheduleLeadAuditor")
  auditScheduleMembershipsV2 AuditScheduleTeamMember[] @relation("AuditScheduleTeamMemberUser")
  createdAuditSchedulesV2    AuditSchedule[]           @relation("AuditScheduleCreatedBy")
  updatedAuditSchedulesV2    AuditSchedule[]           @relation("AuditScheduleUpdatedBy")
  createdAuditProtocolsV2    AuditProtocol[]           @relation("AuditProtocolCreatedBy")
  updatedAuditProtocolsV2    AuditProtocol[]           @relation("AuditProtocolUpdatedBy")

  ledEnterpriseAuditsV2 EnterpriseAudit[] @relation("EnterpriseAuditLeadAuditor")

  ownedEnterpriseAuditsV2 EnterpriseAudit[] @relation("EnterpriseAuditOwner")

  createdEnterpriseAuditsV2 EnterpriseAudit[] @relation("EnterpriseAuditCreatedBy")

  updatedEnterpriseAuditsV2 EnterpriseAudit[] @relation("EnterpriseAuditUpdatedBy")

  enterpriseAuditMembershipsV2 EnterpriseAuditTeamMember[] @relation("EnterpriseAuditTeamMemberUser")

  answeredEnterpriseAuditResponsesV2 EnterpriseAuditResponse[] @relation("EnterpriseAuditResponseAnsweredBy")

  reviewedEnterpriseAuditResponsesV2 EnterpriseAuditResponse[] @relation("EnterpriseAuditResponseReviewedBy")

  capturedEnterpriseAuditEvidenceV2 EnterpriseAuditEvidence[] @relation("EnterpriseAuditEvidenceCapturedBy")

  ownedEnterpriseAuditFindingsV2 EnterpriseAuditFinding[] @relation("EnterpriseAuditFindingOwner")

  createdEnterpriseAuditFindingsV2 EnterpriseAuditFinding[] @relation("EnterpriseAuditFindingCreatedBy")

  updatedEnterpriseAuditFindingsV2 EnterpriseAuditFinding[] @relation("EnterpriseAuditFindingUpdatedBy")

  verifiedEnterpriseAuditFindingsV2 EnterpriseAuditFindingVerification[] @relation("EnterpriseAuditFindingVerifiedBy")

  suggestedEnterpriseAuditActionsV2 EnterpriseAuditFindingActionLink[] @relation("EnterpriseAuditFindingActionSuggestedOwner")

  createdEnterpriseAuditActionLinksV2 EnterpriseAuditFindingActionLink[] @relation("EnterpriseAuditFindingActionCreatedBy")

  reviewedEnterpriseAuditActionLinksV2 EnterpriseAuditFindingActionLink[] @relation("EnterpriseAuditFindingActionReviewedBy")

  createdEnterpriseAuditRiskLinksV2 EnterpriseAuditFindingRiskLink[] @relation("EnterpriseAuditFindingRiskCreatedBy")

  reviewedEnterpriseAuditRiskLinksV2 EnterpriseAuditFindingRiskLink[] @relation("EnterpriseAuditFindingRiskReviewedBy")

  enterpriseAuditHistoryV2 EnterpriseAuditHistory[] @relation("EnterpriseAuditHistoryUser")

  enterpriseAuditFindingHistoryV2 EnterpriseAuditFindingHistory[] @relation("EnterpriseAuditFindingHistoryUser")
  reportedSafetyObservations      SafetyObservation[]             @relation("SafetyObservationReporter")
  assignedSafetyObservations      SafetyObservation[]             @relation("SafetyObservationAssignee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model OrganizationIdentityProvider {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           IdentityProviderType
  issuer         String
  directoryId    String?
  emailDomain    String?
  isEnabled      Boolean              @default(true)
  enforceSso     Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([type, issuer])
  @@index([organizationId, type, isEnabled])
}

model TenantInvitation {
  id             String                 @id @default(cuid())
  organizationId String
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  name           String
  role           UserRole
  departmentId   String?
  tokenHash      String                 @unique
  status         TenantInvitationStatus @default(PENDING)
  expiresAt      DateTime
  invitedById    String
  invitedBy      User                   @relation("TenantInvitationSender", fields: [invitedById], references: [id])
  acceptedById   String?
  acceptedBy     User?                  @relation("TenantInvitationAcceptor", fields: [acceptedById], references: [id])
  acceptedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([organizationId, status, expiresAt])
  @@index([email, status])
}

model Incident {
  id          String       @id @default(cuid())
  title       String
  description String
  type        IncidentType
  riskLevel   RiskLevel    @default(LOW)
  status      Status       @default(OPEN)
  location    String?
  occurredAt  DateTime

  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  reportedById String
  reportedBy   User   @relation("ReportedIncidents", fields: [reportedById], references: [id])

  investigation      Investigation?
  actions            CorrectiveAction[]
  sourceObservations SafetyObservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SafetyObservation {
  id              String                  @id @default(cuid())
  reference       String
  title           String
  description     String
  type            SafetyObservationType
  status          SafetyObservationStatus @default(REPORTED)
  riskLevel       RiskLevel               @default(LOW)
  location        String?
  observedAt      DateTime
  immediateAction String?
  isAnonymous     Boolean                 @default(false)
  reviewNotes     String?
  resolvedAt      DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  siteId         String
  site           Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  reportedById   String
  reportedBy     User         @relation("SafetyObservationReporter", fields: [reportedById], references: [id])
  assignedToId   String?
  assignedTo     User?        @relation("SafetyObservationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  incidentId     String?
  incident       Incident?    @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, reference])
  @@index([organizationId, status])
  @@index([siteId, observedAt])
  @@index([assignedToId, status])
}

model Investigation {
  id                  String  @id @default(cuid())
  summary             String?
  rootCause           String?
  immediateCause      String?
  contributingFactors String?

  status            Status    @default(OPEN)
  dueDate           DateTime?
  reminderSentAt    DateTime?
  overdueNotifiedAt DateTime?

  assignedToId String?
  assignedTo   User?   @relation("InvestigationAssignedUser", fields: [assignedToId], references: [id])

  incidentId String   @unique
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, dueDate])
  @@index([assignedToId])
}

model CorrectiveAction {
  id                String    @id @default(cuid())
  title             String
  description       String?
  status            Status    @default(OPEN)
  riskLevel         RiskLevel @default(LOW)
  dueDate           DateTime
  reminderSentAt    DateTime?
  overdueNotifiedAt DateTime?

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])

  auditFindingId String?       @unique
  auditFinding   AuditFinding? @relation(fields: [auditFindingId], references: [id])

  inspectionFindingId String?            @unique
  inspectionFinding   InspectionFinding? @relation(fields: [inspectionFindingId], references: [id])

  assignedToId String
  assignedTo   User   @relation(fields: [assignedToId], references: [id])

  enterpriseAuditFindingLinks EnterpriseAuditFindingActionLink[] @relation("EnterpriseAuditFindingCorrectiveAction")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, dueDate])
}

model Audit {
  id        String    @id @default(cuid())
  title     String
  reference String?
  scope     String?
  type      AuditType @default(INTERNAL)
  status    Status    @default(OPEN)

  scheduledAt       DateTime?
  dueDate           DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  reminderSentAt    DateTime?
  overdueNotifiedAt DateTime?

  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  leadAuditorId String?
  leadAuditor   User?   @relation("AuditLeadAuditor", fields: [leadAuditorId], references: [id])

  checklistTemplateId String?
  checklistTemplate   AuditChecklistTemplate? @relation(fields: [checklistTemplateId], references: [id])

  teamMembers    AuditTeamMember[]
  checklistItems AuditChecklistItem[]
  responses      AuditResponse[]
  findings       AuditFinding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, status])
  @@index([leadAuditorId])
  @@index([status, dueDate])
  @@index([checklistTemplateId])
}

model AuditTeamMember {
  id        String        @id @default(cuid())
  auditId   String
  userId    String
  role      AuditTeamRole @default(AUDITOR)
  createdAt DateTime      @default(now())

  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([auditId, userId])
  @@index([userId])
}

model AuditChecklistTemplate {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  auditType      AuditType @default(INTERNAL)
  version        Int       @default(1)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sections     AuditChecklistSection[]
  audits       Audit[]

  @@unique([organizationId, name, version])
  @@index([organizationId, auditType, isActive])
}

model AuditChecklistSection {
  id          String   @id @default(cuid())
  templateId  String
  name        String
  description String?
  sequence    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template  AuditChecklistTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions AuditChecklistQuestion[]

  @@unique([templateId, sequence])
}

model AuditChecklistQuestion {
  id           String            @id @default(cuid())
  sectionId    String
  questionText String
  guidance     String?
  questionType AuditQuestionType @default(COMPLIANCE)
  isRequired   Boolean           @default(true)
  weight       Int               @default(1)
  sequence     Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  section        AuditChecklistSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  checklistItems AuditChecklistItem[]

  @@unique([sectionId, sequence])
}

model AuditChecklistItem {
  id                 String            @id @default(cuid())
  auditId            String
  templateQuestionId String?
  sectionName        String
  questionText       String
  guidance           String?
  questionType       AuditQuestionType @default(COMPLIANCE)
  isRequired         Boolean           @default(true)
  weight             Int               @default(1)
  sequence           Int
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  audit            Audit                   @relation(fields: [auditId], references: [id], onDelete: Cascade)
  templateQuestion AuditChecklistQuestion? @relation(fields: [templateQuestionId], references: [id], onDelete: SetNull)
  response         AuditResponse?

  @@unique([auditId, sequence])
  @@index([templateQuestionId])
}

model AuditResponse {
  id              String              @id @default(cuid())
  auditId         String
  checklistItemId String              @unique
  answeredById    String?
  result          AuditResponseResult @default(NOT_ASSESSED)
  responseText    String?
  numericValue    Decimal?            @db.Decimal(18, 4)
  booleanValue    Boolean?
  score           Decimal?            @db.Decimal(8, 2)
  comments        String?
  answeredAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  audit         Audit              @relation(fields: [auditId], references: [id], onDelete: Cascade)
  checklistItem AuditChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  answeredBy    User?              @relation("AuditResponseAnsweredBy", fields: [answeredById], references: [id])
  finding       AuditFinding?

  @@index([auditId, result])
  @@index([answeredById])
}

model AuditFinding {
  id          String    @id @default(cuid())
  title       String
  description String?
  riskLevel   RiskLevel @default(LOW)
  status      Status    @default(OPEN)
  dueDate     DateTime?

  auditId String
  audit   Audit  @relation(fields: [auditId], references: [id], onDelete: Cascade)

  responseId String?        @unique
  response   AuditResponse? @relation(fields: [responseId], references: [id], onDelete: SetNull)

  correctiveAction CorrectiveAction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([auditId, status])
  @@index([riskLevel, dueDate])
}

// ============================================================
// AUDIT MANAGEMENT 2.0 — PLANNING, SCHEDULING, AND PROTOCOLS
// ============================================================

model AuditProgram {
  id             String @id @default(cuid())
  organizationId String

  name        String
  description String?
  code        String?

  standardName    String?
  standardVersion String?
  framework       String?
  objectives      String?
  scope           String?

  status       EnterpriseAuditProgramStatus @default(DRAFT)
  frequency    EnterpriseAuditFrequency
  riskPriority EnterpriseAuditRiskPriority  @default(MEDIUM)

  effectiveFrom DateTime?
  effectiveTo   DateTime?

  ownerId String?

  defaultProtocolId String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation("AuditProgramOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  owner User? @relation("AuditProgramOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  defaultProtocol AuditProtocol? @relation("AuditProgramDefaultProtocol", fields: [defaultProtocolId], references: [id], onDelete: SetNull)

  enterpriseAudits EnterpriseAudit[] @relation("EnterpriseAuditProgram")

  sites       AuditProgramSite[]
  departments AuditProgramDepartment[]
  schedules   AuditSchedule[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId, status, isActive])
  @@index([organizationId, riskPriority])
  @@index([ownerId])
  @@index([defaultProtocolId])
  @@index([effectiveFrom, effectiveTo])
}

model AuditProgramSite {
  id        String @id @default(cuid())
  programId String
  siteId    String

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  program AuditProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  site Site @relation("AuditProgramSiteScope", fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([programId, siteId])
  @@index([siteId])
}

model AuditProgramDepartment {
  id           String @id @default(cuid())
  programId    String
  departmentId String

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  program AuditProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  department Department @relation("AuditProgramDepartmentScope", fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([programId, departmentId])
  @@index([departmentId])
}

model AuditSchedule {
  id             String @id @default(cuid())
  organizationId String
  programId      String

  name        String
  description String?

  status    EnterpriseAuditScheduleStatus @default(ACTIVE)
  frequency EnterpriseAuditFrequency

  intervalValue Int @default(1)

  /**
   * Optional recurrence configuration.
   * Examples:
   * {
   * "weekdays": ["MONDAY"]
   * }
   * {
   * "dayOfMonth": 1
   * }
   * {
   * "month": 1,
   * "dayOfMonth": 15
   * }
   */
  recurrenceRule Json?

  timezone String @default("America/Chicago")

  startDate DateTime
  endDate   DateTime?

  nextRunAt DateTime?
  lastRunAt DateTime?

  generateDaysBefore Int @default(30)
  dueDaysAfter       Int @default(14)

  siteId       String
  departmentId String?

  leadAuditorId String?
  protocolId    String?

  autoGenerate       Boolean @default(true)
  requireTeam        Boolean @default(false)
  requireLeadAuditor Boolean @default(true)

  lastGenerationKey String?
  generationCount   Int     @default(0)

  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation("AuditScheduleOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  program AuditProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  site Site @relation("AuditScheduleSite", fields: [siteId], references: [id], onDelete: Restrict)

  department Department? @relation("AuditScheduleDepartment", fields: [departmentId], references: [id], onDelete: SetNull)

  leadAuditor User? @relation("AuditScheduleLeadAuditor", fields: [leadAuditorId], references: [id], onDelete: SetNull)

  protocol AuditProtocol? @relation("AuditScheduleProtocol", fields: [protocolId], references: [id], onDelete: SetNull)

  createdBy User? @relation("AuditScheduleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedBy User? @relation("AuditScheduleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  enterpriseAudits EnterpriseAudit[] @relation("EnterpriseAuditSchedule")

  teamMembers AuditScheduleTeamMember[]

  @@unique([organizationId, name])
  @@index([organizationId, status, autoGenerate])
  @@index([programId])
  @@index([siteId])
  @@index([departmentId])
  @@index([leadAuditorId])
  @@index([protocolId])
  @@index([nextRunAt, status, autoGenerate])
  @@index([startDate, endDate])
}

model AuditScheduleTeamMember {
  id         String @id @default(cuid())
  scheduleId String
  userId     String

  role EnterpriseAuditScheduleTeamRole @default(AUDITOR)

  isRequired Boolean @default(true)

  createdAt DateTime @default(now())

  schedule AuditSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  user User @relation("AuditScheduleTeamMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, userId])
  @@index([userId])
  @@index([scheduleId, role])
}

model AuditProtocol {
  id             String @id @default(cuid())
  organizationId String

  name        String
  description String?
  code        String?

  standardName    String?
  standardVersion String?
  framework       String?

  version Int @default(1)

  status   EnterpriseAuditProtocolStatus @default(DRAFT)
  isActive Boolean                       @default(true)

  effectiveFrom DateTime?
  effectiveTo   DateTime?

  /**
   * When a protocol is revised, this can point back to the
   * preceding version while retaining the complete history.
   */
  previousVersionId String?

  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation("AuditProtocolOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  previousVersion AuditProtocol? @relation("AuditProtocolVersionHistory", fields: [previousVersionId], references: [id], onDelete: SetNull)

  newerVersions AuditProtocol[] @relation("AuditProtocolVersionHistory")

  createdBy User? @relation("AuditProtocolCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedBy User? @relation("AuditProtocolUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  enterpriseAudits EnterpriseAudit[] @relation("EnterpriseAuditProtocol")

  sections AuditProtocolSection[]

  defaultForPrograms AuditProgram[] @relation("AuditProgramDefaultProtocol")

  schedules AuditSchedule[] @relation("AuditScheduleProtocol")

  @@unique([organizationId, name, version])
  @@unique([organizationId, code, version])
  @@index([organizationId, status, isActive])
  @@index([previousVersionId])
  @@index([effectiveFrom, effectiveTo])
}

model AuditProtocolSection {
  id         String @id @default(cuid())
  protocolId String

  title       String
  description String?
  guidance    String?
  standardRef String?

  sequence Int
  weight   Int @default(1)

  isRequired Boolean @default(true)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  protocol           AuditProtocol            @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  executionSnapshots EnterpriseAuditSection[] @relation("EnterpriseAuditSourceProtocolSection")

  questions AuditProtocolQuestion[]

  @@unique([protocolId, sequence])
  @@index([protocolId, isActive])
}

model AuditProtocolQuestion {
  id        String @id @default(cuid())
  sectionId String

  questionText String
  description  String?
  guidance     String?

  standardClause String?
  regulatoryRef  String?

  responseType EnterpriseAuditQuestionResponseType

  sequence Int
  weight   Int @default(1)

  isRequired Boolean @default(true)
  isActive   Boolean @default(true)

  allowNotApplicable Boolean @default(true)
  requireComment     Boolean @default(false)
  requireEvidence    Boolean @default(false)
  requirePhoto       Boolean @default(false)

  minimumNumericValue Decimal? @db.Decimal(18, 4)
  maximumNumericValue Decimal? @db.Decimal(18, 4)

  minimumPassingScore Decimal? @db.Decimal(8, 2)
  maximumScore        Decimal? @db.Decimal(8, 2)

  findingTrigger  EnterpriseAuditFindingTrigger @default(MANUAL_REVIEW)
  defaultSeverity EnterpriseAuditSeverity?

  automaticallyCreateFinding Boolean @default(false)
  automaticallySuggestCapa   Boolean @default(false)
  automaticallySuggestRisk   Boolean @default(false)

  findingTitleTemplate       String?
  findingDescriptionTemplate String?

  aiGuidance String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section AuditProtocolSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  options AuditQuestionOption[]

  executionSnapshots EnterpriseAuditQuestion[] @relation("EnterpriseAuditSourceProtocolQuestion")

  @@unique([sectionId, sequence])
  @@index([sectionId, isActive])
  @@index([responseType])
  @@index([findingTrigger, automaticallyCreateFinding])
}

model AuditQuestionOption {
  id         String @id @default(cuid())
  questionId String

  label       String
  value       String
  description String?

  sequence Int

  scoreValue Decimal? @db.Decimal(8, 2)

  isPassing       Boolean?
  triggersFinding Boolean  @default(false)

  findingSeverity EnterpriseAuditSeverity?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  question           AuditProtocolQuestion                   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  executionSnapshots EnterpriseAuditQuestionOptionSnapshot[] @relation("EnterpriseAuditSourceQuestionOption")

  @@unique([questionId, value])
  @@unique([questionId, sequence])
  @@index([questionId, isActive])
}

// ============================================================
// AUDIT MANAGEMENT 2.0 — EXECUTION, FINDINGS, AND TRACEABILITY
// ============================================================

model EnterpriseAudit {
  id             String @id @default(cuid())
  organizationId String

  reference String
  title     String

  description String?
  objectives  String?
  scope       String?
  criteria    String?

  source EnterpriseAuditSource @default(MANUAL)
  status EnterpriseAuditStatus @default(DRAFT)

  auditType AuditType @default(INTERNAL)

  programId  String?
  scheduleId String?
  protocolId String?

  siteId       String
  departmentId String?

  leadAuditorId String?
  ownerId       String?

  scheduledAt DateTime?
  dueDate     DateTime?
  startedAt   DateTime?
  submittedAt DateTime?
  completedAt DateTime?
  closedAt    DateTime?
  cancelledAt DateTime?

  cancellationReason String?

  totalQuestionCount     Int @default(0)
  answeredQuestionCount  Int @default(0)
  compliantQuestionCount Int @default(0)
  failedQuestionCount    Int @default(0)
  notApplicableCount     Int @default(0)

  maximumPossibleScore Decimal? @db.Decimal(12, 2)
  achievedScore        Decimal? @db.Decimal(12, 2)
  scorePercentage      Decimal? @db.Decimal(8, 2)

  findingCount         Int @default(0)
  openFindingCount     Int @default(0)
  highRiskFindingCount Int @default(0)

  overallRiskLevel EnterpriseAuditSeverity?
  overallOpinion   String?

  executiveSummary  String?
  positivePractices String?
  majorConcerns     String?
  recommendations   String?

  reminderSentAt    DateTime?
  overdueNotifiedAt DateTime?

  generatedByScheduleKey String?

  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation("EnterpriseAuditOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  program AuditProgram? @relation("EnterpriseAuditProgram", fields: [programId], references: [id], onDelete: SetNull)

  schedule AuditSchedule? @relation("EnterpriseAuditSchedule", fields: [scheduleId], references: [id], onDelete: SetNull)

  protocol AuditProtocol? @relation("EnterpriseAuditProtocol", fields: [protocolId], references: [id], onDelete: SetNull)

  site Site @relation("EnterpriseAuditSite", fields: [siteId], references: [id], onDelete: Restrict)

  department Department? @relation("EnterpriseAuditDepartment", fields: [departmentId], references: [id], onDelete: SetNull)

  leadAuditor User? @relation("EnterpriseAuditLeadAuditor", fields: [leadAuditorId], references: [id], onDelete: SetNull)

  owner User? @relation("EnterpriseAuditOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdBy User? @relation("EnterpriseAuditCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedBy User? @relation("EnterpriseAuditUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  teamMembers EnterpriseAuditTeamMember[]
  sections    EnterpriseAuditSection[]
  questions   EnterpriseAuditQuestion[]
  responses   EnterpriseAuditResponse[]
  evidence    EnterpriseAuditEvidence[]
  findings    EnterpriseAuditFinding[]
  history     EnterpriseAuditHistory[]

  @@unique([organizationId, reference])
  @@unique([scheduleId, generatedByScheduleKey])
  @@index([organizationId, status])
  @@index([organizationId, auditType, status])
  @@index([programId])
  @@index([scheduleId])
  @@index([protocolId])
  @@index([siteId, status])
  @@index([departmentId, status])
  @@index([leadAuditorId])
  @@index([ownerId])
  @@index([scheduledAt])
  @@index([dueDate, status])
  @@index([completedAt])
  @@index([overallRiskLevel])
}

model EnterpriseAuditTeamMember {
  id      String @id @default(cuid())
  auditId String
  userId  String

  role EnterpriseAuditTeamRole @default(AUDITOR)

  isRequired Boolean @default(true)
  canEdit    Boolean @default(true)
  canReview  Boolean @default(false)

  assignedAt DateTime  @default(now())
  acceptedAt DateTime?
  declinedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  audit EnterpriseAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  user User @relation("EnterpriseAuditTeamMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([auditId, userId])
  @@index([userId])
  @@index([auditId, role])
}

model EnterpriseAuditSection {
  id      String @id @default(cuid())
  auditId String

  sourceProtocolSectionId String?

  title       String
  description String?
  guidance    String?
  standardRef String?

  sequence Int
  weight   Int @default(1)

  status EnterpriseAuditSectionStatus @default(NOT_STARTED)

  isRequired Boolean @default(true)
  isActive   Boolean @default(true)

  totalQuestionCount    Int @default(0)
  answeredQuestionCount Int @default(0)
  failedQuestionCount   Int @default(0)

  maximumPossibleScore Decimal? @db.Decimal(12, 2)
  achievedScore        Decimal? @db.Decimal(12, 2)
  scorePercentage      Decimal? @db.Decimal(8, 2)

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  audit EnterpriseAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  sourceProtocolSection AuditProtocolSection? @relation("EnterpriseAuditSourceProtocolSection", fields: [sourceProtocolSectionId], references: [id], onDelete: SetNull)

  questions EnterpriseAuditQuestion[]

  @@unique([auditId, sequence])
  @@index([auditId, status])
  @@index([sourceProtocolSectionId])
}

model EnterpriseAuditQuestion {
  id        String @id @default(cuid())
  auditId   String
  sectionId String

  sourceProtocolQuestionId String?

  questionText String
  description  String?
  guidance     String?

  standardClause String?
  regulatoryRef  String?

  responseType EnterpriseAuditQuestionResponseType

  sequence Int
  weight   Int @default(1)

  isRequired Boolean @default(true)
  isActive   Boolean @default(true)

  allowNotApplicable Boolean @default(true)
  requireComment     Boolean @default(false)
  requireEvidence    Boolean @default(false)
  requirePhoto       Boolean @default(false)

  minimumNumericValue Decimal? @db.Decimal(18, 4)
  maximumNumericValue Decimal? @db.Decimal(18, 4)

  minimumPassingScore Decimal? @db.Decimal(8, 2)
  maximumScore        Decimal? @db.Decimal(8, 2)

  findingTrigger  EnterpriseAuditFindingTrigger @default(MANUAL_REVIEW)
  defaultSeverity EnterpriseAuditSeverity?

  automaticallyCreateFinding Boolean @default(false)
  automaticallySuggestCapa   Boolean @default(false)
  automaticallySuggestRisk   Boolean @default(false)

  findingTitleTemplate       String?
  findingDescriptionTemplate String?

  aiGuidance String?

  status EnterpriseAuditQuestionStatus @default(NOT_ASSESSED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  audit EnterpriseAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  section EnterpriseAuditSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  sourceProtocolQuestion AuditProtocolQuestion? @relation("EnterpriseAuditSourceProtocolQuestion", fields: [sourceProtocolQuestionId], references: [id], onDelete: SetNull)

  options  EnterpriseAuditQuestionOptionSnapshot[]
  response EnterpriseAuditResponse?
  evidence EnterpriseAuditEvidence[]
