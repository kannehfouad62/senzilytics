generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  EHS_MANAGER
  SUPERVISOR
  EMPLOYEE
  AUDITOR
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Status {
  OPEN
  IN_PROGRESS
  COMPLETED
  CLOSED
  OVERDUE
}

enum IncidentType {
  INJURY
  NEAR_MISS
  PROPERTY_DAMAGE
  ENVIRONMENTAL
  VEHICLE
  SECURITY
  OTHER
}

enum PermissionKey {
  MANAGE_ORGANIZATION
  MANAGE_USERS
  VIEW_USERS
  VIEW_DASHBOARD
  VIEW_REPORTS
  CREATE_INCIDENT
  VIEW_INCIDENT
  UPDATE_INCIDENT
  DELETE_INCIDENT
  CREATE_CAPA
  UPDATE_CAPA
  CLOSE_CAPA
  VIEW_AUDITS
  MANAGE_AUDITS
  VIEW_INSPECTIONS
  MANAGE_INSPECTIONS
  VIEW_COMPLIANCE
  MANAGE_COMPLIANCE
  VIEW_TRAINING
  MANAGE_TRAINING
  USE_AI
  MANAGE_WORKFLOWS
  VIEW_ACTIVITY_LOG
  MANAGE_NOTIFICATIONS
  MANAGE_DOCUMENTS
}

enum AuditType {
  INTERNAL
  EXTERNAL
  REGULATORY
  COMPLIANCE
  MANAGEMENT_SYSTEM
  SUPPLIER
  PROCESS
  SAFETY
  ENVIRONMENTAL
  OTHER
}

enum AuditTeamRole {
  LEAD_AUDITOR
  AUDITOR
  TECHNICAL_EXPERT
  OBSERVER
}

enum AuditQuestionType {
  YES_NO
  COMPLIANCE
  TEXT
  NUMBER
}

enum AuditResponseResult {
  NOT_ASSESSED
  COMPLIANT
  NON_COMPLIANT
  NOT_APPLICABLE
}

enum InspectionType {
  ROUTINE
  SAFETY
  ENVIRONMENTAL
  EQUIPMENT
  FACILITY
  VEHICLE
  HOUSEKEEPING
  REGULATORY
  PRE_OPERATIONAL
  OTHER
}

enum InspectionTeamRole {
  LEAD_INSPECTOR
  INSPECTOR
  TECHNICAL_EXPERT
  OBSERVER
}

enum InspectionQuestionType {
  YES_NO
  COMPLIANCE
  TEXT
  NUMBER
  PHOTO
}

enum InspectionResponseResult {
  NOT_ASSESSED
  COMPLIANT
  NON_COMPLIANT
  NOT_APPLICABLE
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  LOGIN
  LOGOUT
  ASSIGN
  COMMENT
  SYSTEM
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  CRITICAL
  ASSIGNMENT
  DUE_DATE
  SYSTEM
}

enum WorkflowEntityType {
  INCIDENT
  CORRECTIVE_ACTION
  AUDIT
  INSPECTION
  COMPLIANCE
  TRAINING
  DOCUMENT
  PERMIT
  MOC
  OBSERVATION
}

enum WorkflowStepType {
  START
  REVIEW
  APPROVAL
  TASK
  VERIFICATION
  CLOSE
}

enum WorkflowInstanceStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum WorkflowStepStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  COMPLETED
  SKIPPED
  CANCELLED
}

enum WorkflowDecision {
  APPROVE
  REJECT
  SKIP
}

enum DocumentEntityType {
  INCIDENT
  INVESTIGATION
  CORRECTIVE_ACTION
  AUDIT
  AUDIT_FINDING
  INSPECTION
  INSPECTION_FINDING
  COMPLIANCE
  TRAINING
  WORKFLOW
  ORGANIZATION
  SITE
  USER
  OTHER
}

enum DocumentCategory {
  EVIDENCE
  PHOTO
  VIDEO
  REPORT
  POLICY
  PROCEDURE
  CERTIFICATE
  TRAINING_MATERIAL
  AUDIT_RECORD
  INSPECTION_RECORD
  OTHER
}

enum DocumentStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  industry  String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites                        Site[]
  users                        User[]
  activityLogs                 ActivityLog[]
  notifications                Notification[]
  workflowTemplates            WorkflowTemplate[]
  workflowInstances            WorkflowInstance[]
  documents                    Document[]
  auditChecklistTemplates      AuditChecklistTemplate[]
  inspectionChecklistTemplates InspectionChecklistTemplate[]
}

model Site {
  id             String       @id @default(cuid())
  name           String
  address        String?
  city           String?
  state          String?
  country        String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  departments     Department[]
  incidents       Incident[]
  audits          Audit[]
  inspections     Inspection[]
  complianceItems ComplianceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id     String @id @default(cuid())
  name   String
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  password String?
  role     UserRole @default(EMPLOYEE)
  jobTitle String?
  phone    String?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  reportedIncidents         Incident[]             @relation("ReportedIncidents")
  assignedInvestigations    Investigation[]        @relation("InvestigationAssignedUser")
  assignedActions           CorrectiveAction[]
  leadAudits                Audit[]                @relation("AuditLeadAuditor")
  auditTeamMemberships      AuditTeamMember[]
  auditResponses            AuditResponse[]        @relation("AuditResponseAnsweredBy")
  leadInspections           Inspection[]           @relation("InspectionLeadInspector")
  inspectionTeamMemberships InspectionTeamMember[]
  inspectionResponses       InspectionResponse[]   @relation("InspectionResponseAnsweredBy")
  trainingRecords           TrainingRecord[]
  activityLogs              ActivityLog[]
  notifications             Notification[]
  uploadedDocuments         Document[]

  startedWorkflowInstances WorkflowInstance[]
  assignedWorkflowSteps    WorkflowInstanceStep[] @relation("WorkflowAssignedUser")
  completedWorkflowSteps   WorkflowInstanceStep[] @relation("WorkflowCompletedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Incident {
  id          String       @id @default(cuid())
  title       String
  description String
  type        IncidentType
  riskLevel   RiskLevel    @default(LOW)
  status      Status       @default(OPEN)
  location    String?
  occurredAt  DateTime

  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  reportedById String
  reportedBy   User   @relation("ReportedIncidents", fields: [reportedById], references: [id])

  investigation Investigation?
  actions       CorrectiveAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Investigation {
  id                  String  @id @default(cuid())
  summary             String?
  rootCause           String?
  immediateCause      String?
  contributingFactors String?

  status            Status    @default(OPEN)
  dueDate           DateTime?
  reminderSentAt    DateTime?
  overdueNotifiedAt DateTime?

  assignedToId String?
  assignedTo   User?   @relation("InvestigationAssignedUser", fields: [assignedToId], references: [id])

  incidentId String   @unique
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, dueDate])
  @@index([assignedToId])
}

model CorrectiveAction {
  id                String    @id @default(cuid())
  title             String
  description       String?
  status            Status    @default(OPEN)
  riskLevel         RiskLevel @default(LOW)
  dueDate           DateTime
  reminderSentAt    DateTime?
  overdueNotifiedAt DateTime?

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])

  auditFindingId String?       @unique
  auditFinding   AuditFinding? @relation(fields: [auditFindingId], references: [id])

  inspectionFindingId String?            @unique
  inspectionFinding   InspectionFinding? @relation(fields: [inspectionFindingId], references: [id])

  assignedToId String
  assignedTo   User   @relation(fields: [assignedToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, dueDate])
}

model Audit {
  id        String    @id @default(cuid())
  title     String
  reference String?
  scope     String?
  type      AuditType @default(INTERNAL)
  status    Status    @default(OPEN)

  scheduledAt       DateTime?
  dueDate           DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  reminderSentAt    DateTime?
  overdueNotifiedAt DateTime?

  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  leadAuditorId String?
  leadAuditor   User?   @relation("AuditLeadAuditor", fields: [leadAuditorId], references: [id])

  checklistTemplateId String?
  checklistTemplate   AuditChecklistTemplate? @relation(fields: [checklistTemplateId], references: [id])

  teamMembers    AuditTeamMember[]
  checklistItems AuditChecklistItem[]
  responses      AuditResponse[]
  findings       AuditFinding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, status])
  @@index([leadAuditorId])
  @@index([status, dueDate])
  @@index([checklistTemplateId])
}

model AuditTeamMember {
  id        String        @id @default(cuid())
  auditId   String
  userId    String
  role      AuditTeamRole @default(AUDITOR)
  createdAt DateTime      @default(now())

  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([auditId, userId])
  @@index([userId])
}

model AuditChecklistTemplate {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  auditType      AuditType @default(INTERNAL)
  version        Int       @default(1)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sections     AuditChecklistSection[]
  audits       Audit[]

  @@unique([organizationId, name, version])
  @@index([organizationId, auditType, isActive])
}

model AuditChecklistSection {
  id          String   @id @default(cuid())
  templateId  String
  name        String
  description String?
  sequence    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template  AuditChecklistTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions AuditChecklistQuestion[]

  @@unique([templateId, sequence])
}

model AuditChecklistQuestion {
  id           String            @id @default(cuid())
  sectionId    String
  questionText String
  guidance     String?
  questionType AuditQuestionType @default(COMPLIANCE)
  isRequired   Boolean           @default(true)
  weight       Int               @default(1)
  sequence     Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  section        AuditChecklistSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  checklistItems AuditChecklistItem[]

  @@unique([sectionId, sequence])
}

model AuditChecklistItem {
  id                 String            @id @default(cuid())
  auditId            String
  templateQuestionId String?
  sectionName        String
  questionText       String
  guidance           String?
  questionType       AuditQuestionType @default(COMPLIANCE)
  isRequired         Boolean           @default(true)
  weight             Int               @default(1)
  sequence           Int
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  audit            Audit                   @relation(fields: [auditId], references: [id], onDelete: Cascade)
  templateQuestion AuditChecklistQuestion? @relation(fields: [templateQuestionId], references: [id], onDelete: SetNull)
  response         AuditResponse?

  @@unique([auditId, sequence])
  @@index([templateQuestionId])
}

model AuditResponse {
  id              String              @id @default(cuid())
  auditId         String
  checklistItemId String              @unique
  answeredById    String?
  result          AuditResponseResult @default(NOT_ASSESSED)
  responseText    String?
  numericValue    Decimal?            @db.Decimal(18, 4)
  booleanValue    Boolean?
  score           Decimal?            @db.Decimal(8, 2)
  comments        String?
  answeredAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  audit         Audit              @relation(fields: [auditId], references: [id], onDelete: Cascade)
  checklistItem AuditChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  answeredBy    User?              @relation("AuditResponseAnsweredBy", fields: [answeredById], references: [id])
  finding       AuditFinding?

  @@index([auditId, result])
  @@index([answeredById])
}

model AuditFinding {
  id          String    @id @default(cuid())
  title       String
  description String?
  riskLevel   RiskLevel @default(LOW)
  status      Status    @default(OPEN)
  dueDate     DateTime?

  auditId String
  audit   Audit  @relation(fields: [auditId], references: [id], onDelete: Cascade)

  responseId String?        @unique
  response   AuditResponse? @relation(fields: [responseId], references: [id], onDelete: SetNull)

  correctiveAction CorrectiveAction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([auditId, status])
  @@index([riskLevel, dueDate])
}

model Inspection {
  id          String         @id @default(cuid())
  title       String
  reference   String?
  description String?
  area        String?
  type        InspectionType @default(ROUTINE)
  status      Status         @default(OPEN)

  scheduledAt       DateTime?
  dueDate           DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  reminderSentAt    DateTime?
  overdueNotifiedAt DateTime?

  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  leadInspectorId String?
  leadInspector   User?   @relation("InspectionLeadInspector", fields: [leadInspectorId], references: [id])

  checklistTemplateId String?
  checklistTemplate   InspectionChecklistTemplate? @relation(fields: [checklistTemplateId], references: [id])

  teamMembers    InspectionTeamMember[]
  checklistItems InspectionChecklistItem[]
  responses      InspectionResponse[]
  findings       InspectionFinding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, status])
  @@index([leadInspectorId])
  @@index([status, dueDate])
  @@index([checklistTemplateId])
}

model InspectionTeamMember {
  id           String             @id @default(cuid())
  inspectionId String
  userId       String
  role         InspectionTeamRole @default(INSPECTOR)
  createdAt    DateTime           @default(now())

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([inspectionId, userId])
  @@index([userId])
}

model InspectionChecklistTemplate {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  description    String?
  inspectionType InspectionType @default(ROUTINE)
  version        Int            @default(1)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sections     InspectionChecklistSection[]
  inspections  Inspection[]

  @@unique([organizationId, name, version])
  @@index([organizationId, inspectionType, isActive])
}

model InspectionChecklistSection {
  id          String   @id @default(cuid())
  templateId  String
  name        String
  description String?
  sequence    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template  InspectionChecklistTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions InspectionChecklistQuestion[]

  @@unique([templateId, sequence])
}

model InspectionChecklistQuestion {
  id           String                 @id @default(cuid())
  sectionId    String
  questionText String
  guidance     String?
  questionType InspectionQuestionType @default(COMPLIANCE)
  isRequired   Boolean                @default(true)
  weight       Int                    @default(1)
  sequence     Int
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  section        InspectionChecklistSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  checklistItems InspectionChecklistItem[]

  @@unique([sectionId, sequence])
}

model InspectionChecklistItem {
  id                 String                 @id @default(cuid())
  inspectionId       String
  templateQuestionId String?
  sectionName        String
  questionText       String
  guidance           String?
  questionType       InspectionQuestionType @default(COMPLIANCE)
  isRequired         Boolean                @default(true)
  weight             Int                    @default(1)
  sequence           Int
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  inspection       Inspection                   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  templateQuestion InspectionChecklistQuestion? @relation(fields: [templateQuestionId], references: [id], onDelete: SetNull)
  response         InspectionResponse?

  @@unique([inspectionId, sequence])
  @@index([templateQuestionId])
}

model InspectionResponse {
  id              String                   @id @default(cuid())
  inspectionId    String
  checklistItemId String                   @unique
  answeredById    String?
  result          InspectionResponseResult @default(NOT_ASSESSED)
  responseText    String?
  numericValue    Decimal?                 @db.Decimal(18, 4)
  booleanValue    Boolean?
  score           Decimal?                 @db.Decimal(8, 2)
  comments        String?
  answeredAt      DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  inspection    Inspection              @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  checklistItem InspectionChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  answeredBy    User?                   @relation("InspectionResponseAnsweredBy", fields: [answeredById], references: [id])
  finding       InspectionFinding?

  @@index([inspectionId, result])
  @@index([answeredById])
}

model InspectionFinding {
  id          String    @id @default(cuid())
  title       String
  description String?
  riskLevel   RiskLevel @default(LOW)
  status      Status    @default(OPEN)
  dueDate     DateTime?

  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  responseId String?             @unique
  response   InspectionResponse? @relation(fields: [responseId], references: [id], onDelete: SetNull)

  correctiveAction CorrectiveAction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inspectionId, status])
  @@index([riskLevel, dueDate])
}

model ComplianceItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      Status   @default(OPEN)
  dueDate     DateTime

  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainingRecord {
  id          String    @id @default(cuid())
  courseName  String
  status      Status    @default(OPEN)
  dueDate     DateTime?
  completedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RolePermission {
  id         String        @id @default(cuid())
  role       UserRole
  permission PermissionKey
  

  createdAt DateTime @default(now())

  @@unique([role, permission])
}

model ActivityLog {
  id             String         @id @default(cuid())
  organizationId String
  userId         String?
  action         ActivityAction
  entityType     String
  entityId       String?
  title          String
  description    String?
  metadata       Json?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  type           NotificationType @default(INFO)
  title          String
  message        String
  link           String?
  readAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkflowTemplate {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  description    String?
  entityType     WorkflowEntityType
  isActive       Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps        WorkflowTemplateStep[]
  instances    WorkflowInstance[]

  @@index([organizationId, entityType, isActive])
}

model WorkflowTemplateStep {
  id           String           @id @default(cuid())
  templateId   String
  name         String
  description  String?
  stepType     WorkflowStepType
  sequence     Int
  requiredRole UserRole?
  slaHours     Int?

  approveNextStepId String?
  rejectNextStepId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  approveNextStep WorkflowTemplateStep? @relation("ApproveNextStep", fields: [approveNextStepId], references: [id])

  rejectNextStep WorkflowTemplateStep? @relation("RejectNextStep", fields: [rejectNextStepId], references: [id])

  approveParents WorkflowTemplateStep[] @relation("ApproveNextStep")
  rejectParents  WorkflowTemplateStep[] @relation("RejectNextStep")

  @@unique([templateId, sequence])
}

model WorkflowInstance {
  id             String                 @id @default(cuid())
  organizationId String
  templateId     String
  entityType     WorkflowEntityType
  entityId       String
  status         WorkflowInstanceStatus @default(ACTIVE)
  currentStepId  String?

  startedById String?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     WorkflowTemplate       @relation(fields: [templateId], references: [id])
  startedBy    User?                  @relation(fields: [startedById], references: [id])
  steps        WorkflowInstanceStep[]
}

model WorkflowInstanceStep {
  id             String @id @default(cuid())
  instanceId     String
  templateStepId String

  name     String
  stepType WorkflowStepType
  sequence Int

  status WorkflowStepStatus @default(PENDING)

  assignedRole   UserRole?
  assignedUserId String?

  completedById String?

  decision WorkflowDecision?
  comments String?

  startedAt         DateTime?
  dueAt             DateTime?
  completedAt       DateTime?
  escalationSentAt  DateTime?
  reminderSentAt    DateTime?
  overdueNotifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  assignedUser User? @relation("WorkflowAssignedUser", fields: [assignedUserId], references: [id])
  completedBy  User? @relation("WorkflowCompletedBy", fields: [completedById], references: [id])

  @@index([status, dueAt])
}

model Document {
  id             String  @id @default(cuid())
  organizationId String
  uploadedById   String?

  entityType DocumentEntityType
  entityId   String

  category DocumentCategory @default(OTHER)
  status   DocumentStatus   @default(ACTIVE)

  name         String
  originalName String
  description  String?

  storageKey String
  storageUrl String
  mimeType   String
  sizeBytes  Int

  version        Int     @default(1)
  versionGroupId String  @default(cuid())
  isLatest       Boolean @default(true)
  checksum       String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?
  deletedAt  DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User?        @relation(fields: [uploadedById], references: [id])

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, status])
  @@index([organizationId, checksum])
  @@index([organizationId, versionGroupId, version])
  @@index([uploadedById])
}
