  periodEnd           DateTime
  boundaryDescription String
  status              EsgDisclosureStatus @default(DRAFT)
  approvedById        String?
  approvedBy          User?               @relation("EsgPeriodApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt          DateTime?
  publishedById       String?
  publishedBy         User?               @relation("EsgPeriodPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  publishedAt         DateTime?
  dataPoints          EsgDataPoint[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, status, periodEnd])
}

model EsgDataPoint {
  id                String              @id @default(cuid())
  periodId          String
  period            EsgDisclosurePeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  metricId          String
  metric            EsgMetricDefinition @relation(fields: [metricId], references: [id], onDelete: Cascade)
  value             Float
  quality           EsgDataQuality
  evidenceSummary   String?
  sourceDescription String?
  isAutoCalculated  Boolean             @default(false)
  sourceRecordCount Int                 @default(0)
  enteredById       String
  enteredBy         User                @relation("EsgDataEnteredBy", fields: [enteredById], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([periodId, metricId])
  @@index([metricId, periodId])
}

model EsgTarget {
  id            String              @id @default(cuid())
  metricId      String
  metric        EsgMetricDefinition @relation(fields: [metricId], references: [id], onDelete: Cascade)
  baselineYear  Int
  baselineValue Float
  targetYear    Int
  targetValue   Float
  description   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([metricId, targetYear])
}

model EsgInitiative {
  id              String              @id @default(cuid())
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  pillar          EsgPillar
  status          EsgInitiativeStatus @default(PLANNED)
  ownerId         String?
  owner           User?               @relation("EsgInitiativeOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  startDate       DateTime?
  targetDate      DateTime?
  budget          Float?
  expectedOutcome String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([organizationId, pillar, status])
  @@index([ownerId, status])
}

model JobSafetyAnalysis {
  id                    String              @id @default(cuid())
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  siteId                String
  site                  Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  departmentId          String?
  department            Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  reference             String
  title                 String
  jobDescription        String
  workLocation          String?
  requiredCompetency    String?
  requiredPpe           String?
  emergencyRequirements String?
  version               Int                 @default(1)
  status                JsaStatus           @default(DRAFT)
  ownerId               String?
  owner                 User?               @relation("JsaOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdById           String
  createdBy             User                @relation("JsaCreatedBy", fields: [createdById], references: [id])
  approvedById          String?
  approvedBy            User?               @relation("JsaApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt            DateTime?
  effectiveDate         DateTime?
  reviewDueDate         DateTime?
  steps                 JsaStep[]
  acknowledgments       JsaAcknowledgment[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([organizationId, reference, version])
  @@index([organizationId, status])
  @@index([siteId, status])
  @@index([ownerId, reviewDueDate])
}

model JsaStep {
  id        String            @id @default(cuid())
  jsaId     String
  jsa       JobSafetyAnalysis @relation(fields: [jsaId], references: [id], onDelete: Cascade)
  sequence  Int
  taskStep  String
  hazards   JsaHazard[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([jsaId, sequence])
}

model JsaHazard {
  id                   String         @id @default(cuid())
  stepId               String
  step                 JsaStep        @relation(fields: [stepId], references: [id], onDelete: Cascade)
  hazard               String
  potentialConsequence String
  initialLikelihood    RiskLikelihood
  initialImpact        RiskImpact
  initialScore         Int
  residualLikelihood   RiskLikelihood
  residualImpact       RiskImpact
  residualScore        Int
  riskId               String?
  risk                 Risk?          @relation(fields: [riskId], references: [id], onDelete: SetNull)
  controls             JsaControl[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([stepId])
  @@index([riskId])
}

model JsaControl {
  id                   String              @id @default(cuid())
  hazardId             String
  hazard               JsaHazard           @relation(fields: [hazardId], references: [id], onDelete: Cascade)
  hierarchy            JsaControlHierarchy
  description          String
  responsibleRole      String?
  verificationRequired Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([hazardId, hierarchy])
}

model JsaAcknowledgment {
  id             String            @id @default(cuid())
  jsaId          String
  jsa            JobSafetyAnalysis @relation(fields: [jsaId], references: [id], onDelete: Cascade)
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  acknowledgedAt DateTime          @default(now())
  statement      String?

  @@unique([jsaId, userId])
  @@index([userId, acknowledgedAt])
}

model TrainingRecord {
  id          String    @id @default(cuid())
  courseName  String
  status      Status    @default(OPEN)
  dueDate     DateTime?
  completedAt DateTime?

  userId String
  user   User   @relation("TrainingRecordLearner", fields: [userId], references: [id])

  courseId          String?
  course            TrainingCourse?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  assignedById      String?
  assignedBy        User?                @relation("TrainingRecordAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  assignedAt        DateTime             @default(now())
  expiresAt         DateTime?
  provider          String?
  certificateNumber String?
  score             Float?
  notes             String?
  requirementId     String?
  requirement       TrainingRequirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  generationKey     String?              @unique
  reminderSentAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId, status])
  @@index([userId, dueDate])
  @@index([expiresAt])
  @@index([requirementId, status])
}

model TrainingCourse {
  id             String                @id @default(cuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  name           String
  description    String?
  provider       String?
  validityMonths Int?
  isActive       Boolean               @default(true)
  createdById    String?
  createdBy      User?                 @relation("TrainingCourseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  requirements   TrainingRequirement[]
  records        TrainingRecord[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

model TrainingRequirement {
  id              String           @id @default(cuid())
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  courseId        String
  course          TrainingCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  role            UserRole?
  siteId          String?
  site            Site?            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  departmentId    String?
  department      Department?      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  dueWithinDays   Int              @default(30)
  renewalLeadDays Int              @default(30)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  records         TrainingRecord[]

  @@index([organizationId, isActive])
  @@index([courseId])
}

model Risk {
  id          String @id @default(cuid())
  reference   String
  title       String
  description String

  category   RiskCategory
  hazardType String?
  process    String?
  status     RiskStatus   @default(DRAFT)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  ownerId String?
  owner   User?   @relation("RiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  initialLikelihood RiskLikelihood
  initialImpact     RiskImpact
  initialScore      Int
  initialRiskLevel  RiskLevel

  currentLikelihood RiskLikelihood
  currentImpact     RiskImpact
  currentScore      Int
  currentRiskLevel  RiskLevel

  residualLikelihood RiskLikelihood
  residualImpact     RiskImpact
  residualScore      Int
  residualRiskLevel  RiskLevel

  reviewFrequency RiskReviewFrequency @default(ANNUAL)
  lastReviewedAt  DateTime?
  nextReviewDate  DateTime?

  controls RiskControl[]
  reviews  RiskReview[]
  links    RiskLink[]
  mocLinks MocRiskLink[]

  enterpriseAuditFindingLinks EnterpriseAuditFindingRiskLink[] @relation("EnterpriseAuditFindingRisk")
  jsaHazards                  JsaHazard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, reference])
  @@index([organizationId, status])
  @@index([organizationId, category])
  @@index([siteId, status])
  @@index([departmentId])
  @@index([ownerId])
  @@index([currentRiskLevel, nextReviewDate])
  @@index([residualRiskLevel, nextReviewDate])
}

model RiskControl {
  id          String  @id @default(cuid())
  name        String
  description String?

  controlType   RiskControlType
  hierarchy     RiskControlHierarchy
  effectiveness RiskControlEffectiveness @default(NOT_ASSESSED)

  status Status @default(OPEN)

  ownerId String?
  owner   User?   @relation("RiskControlOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  dueDate            DateTime?
  implementedAt      DateTime?
  verificationDate   DateTime?
  verificationMethod String?
  verificationResult String?

  riskId String
  risk   Risk   @relation(fields: [riskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riskId, controlType])
  @@index([riskId, status])
  @@index([ownerId])
  @@index([effectiveness])
  @@index([dueDate])
}

model RiskReview {
  id String @id @default(cuid())

  reviewDate DateTime @default(now())
  notes      String?

  likelihood RiskLikelihood
  impact     RiskImpact
  score      Int
  riskLevel  RiskLevel

  controlEffectiveness RiskControlEffectiveness?
  trend                String?
  nextReviewDate       DateTime?

  riskId String
  risk   Risk   @relation(fields: [riskId], references: [id], onDelete: Cascade)

  completedById String?
  completedBy   User?   @relation("RiskReviewCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riskId, reviewDate])
  @@index([completedById])
  @@index([riskLevel])
}

model RiskLink {
  id String @id @default(cuid())

  entityType RiskLinkedEntityType
  entityId   String
  label      String?

  riskId String
  risk   Risk   @relation(fields: [riskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([riskId, entityType, entityId])
  @@index([entityType, entityId])
}

model ManagementOfChange {
  id                    String @id @default(cuid())
  reference             String
  title                 String
  description           String
  businessJustification String

  changeType     MocChangeType
  changeDuration MocChangeDuration
  priority       MocPriority       @default(MEDIUM)
  status         MocStatus         @default(DRAFT)

  emergencyJustification  String?
  temporaryExpirationDate DateTime?

  affectedProcess     String?
  affectedEquipment   String?
  affectedSystems     String?
  affectedMaterials   String?
  operationalImpact   String?
  regulatoryImpact    String?
  environmentalImpact String?
  safetyImpact        String?
  qualityImpact       String?

  initialLikelihood RiskLikelihood
  initialImpact     RiskImpact
  initialScore      Int
  initialRiskLevel  RiskLevel

  residualLikelihood RiskLikelihood
  residualImpact     RiskImpact
  residualScore      Int
  residualRiskLevel  RiskLevel

  proposedStartDate     DateTime?
  plannedCompletionDate DateTime?
  actualStartDate       DateTime?
  implementedAt         DateTime?
  verifiedAt            DateTime?
  closedAt              DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Restrict)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  requestorId String
  requestor   User   @relation("MocRequestor", fields: [requestorId], references: [id], onDelete: Restrict)

  ownerId String?
  owner   User?   @relation("MocOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  approvals     MocApproval[]
  tasks         MocTask[]
  riskLinks     MocRiskLink[]
  chemicalLinks ChemicalMocLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, reference])
  @@index([organizationId, status])
  @@index([organizationId, changeType])
  @@index([siteId, status])
  @@index([departmentId])
  @@index([requestorId])
  @@index([ownerId])
  @@index([priority, status])
  @@index([residualRiskLevel, status])
  @@index([plannedCompletionDate, status])
}

model MocApproval {
  id String @id @default(cuid())

  role     MocApprovalRole
  status   MocApprovalStatus @default(PENDING)
  sequence Int

  comments    String?
  requestedAt DateTime  @default(now())
  decidedAt   DateTime?

  mocId String
  moc   ManagementOfChange @relation(fields: [mocId], references: [id], onDelete: Cascade)

  approverId String?
  approver   User?   @relation("MocApprover", fields: [approverId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mocId, role, sequence])
  @@index([mocId, status])
  @@index([approverId])
}

model MocTask {
  id          String  @id @default(cuid())
  title       String
  description String?

  taskType MocTaskType
  status   MocTaskStatus @default(NOT_STARTED)
  sequence Int?

  isRequired Boolean @default(true)

  dueDate      DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  verifiedAt   DateTime?
  evidenceNote String?

  mocId String
  moc   ManagementOfChange @relation(fields: [mocId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?   @relation("MocTaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  verifiedById String?
  verifiedBy   User?   @relation("MocTaskVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mocId, status])
  @@index([mocId, taskType])
  @@index([assignedToId])
  @@index([dueDate, status])
}

model MocRiskLink {
  id String @id @default(cuid())

  relationshipNote String?

  mocId String
  moc   ManagementOfChange @relation(fields: [mocId], references: [id], onDelete: Cascade)

  riskId String
  risk   Risk   @relation(fields: [riskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([mocId, riskId])
  @@index([riskId])
}

model RolePermission {
  id         String        @id @default(cuid())
  role       UserRole
  permission PermissionKey

  createdAt DateTime @default(now())

  @@unique([role, permission])
}

model ActivityLog {
  id             String         @id @default(cuid())
  organizationId String
  userId         String?
  action         ActivityAction
  entityType     String
  entityId       String?
  title          String
  description    String?
  metadata       Json?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  type           NotificationType @default(INFO)
  title          String
  message        String
  link           String?
  readAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkflowTemplate {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  description    String?
  entityType     WorkflowEntityType
  isActive       Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps        WorkflowTemplateStep[]
  instances    WorkflowInstance[]

  @@index([organizationId, entityType, isActive])
}

model WorkflowTemplateStep {
  id           String           @id @default(cuid())
  templateId   String
  name         String
  description  String?
  stepType     WorkflowStepType
  sequence     Int
  requiredRole UserRole?
  slaHours     Int?

  approveNextStepId String?
  rejectNextStepId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  approveNextStep WorkflowTemplateStep? @relation("ApproveNextStep", fields: [approveNextStepId], references: [id])

  rejectNextStep WorkflowTemplateStep? @relation("RejectNextStep", fields: [rejectNextStepId], references: [id])

  approveParents WorkflowTemplateStep[] @relation("ApproveNextStep")
  rejectParents  WorkflowTemplateStep[] @relation("RejectNextStep")

  @@unique([templateId, sequence])
}

model WorkflowInstance {
  id             String                 @id @default(cuid())
  organizationId String
  templateId     String
  entityType     WorkflowEntityType
  entityId       String
  status         WorkflowInstanceStatus @default(ACTIVE)
  currentStepId  String?

  startedById String?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     WorkflowTemplate       @relation(fields: [templateId], references: [id])
  startedBy    User?                  @relation(fields: [startedById], references: [id])
  steps        WorkflowInstanceStep[]
}

model WorkflowInstanceStep {
  id             String @id @default(cuid())
  instanceId     String
  templateStepId String

  name     String
  stepType WorkflowStepType
  sequence Int

  status WorkflowStepStatus @default(PENDING)

  assignedRole   UserRole?
  assignedUserId String?

  completedById String?

  decision WorkflowDecision?
  comments String?

  startedAt         DateTime?
  dueAt             DateTime?
  completedAt       DateTime?
  escalationSentAt  DateTime?
  reminderSentAt    DateTime?
  overdueNotifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  assignedUser User? @relation("WorkflowAssignedUser", fields: [assignedUserId], references: [id])
  completedBy  User? @relation("WorkflowCompletedBy", fields: [completedById], references: [id])

  @@index([status, dueAt])
}

model Document {
  id             String  @id @default(cuid())
  organizationId String
  uploadedById   String?

  entityType DocumentEntityType
  entityId   String

  category DocumentCategory @default(OTHER)
  status   DocumentStatus   @default(ACTIVE)

  name         String
  originalName String
  description  String?

  storageKey String
  storageUrl String
  mimeType   String
  sizeBytes  Int

  version        Int     @default(1)
  versionGroupId String  @default(cuid())
  isLatest       Boolean @default(true)
  checksum       String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?
  deletedAt  DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User?        @relation(fields: [uploadedById], references: [id])

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, status])
  @@index([organizationId, checksum])
  @@index([organizationId, versionGroupId, version])
  @@index([uploadedById])
}
